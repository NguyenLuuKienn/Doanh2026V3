@model Doanh2026.Models.SanPham
@{
    ViewBag.Title = Model.TenSanPham;
    Layout = "~/Views/Shared/_LayoutIndex.cshtml";

    var basePrice = Model.GiaUuDai ?? Model.GiaGoc;
    var oldPrice = Model.GiaGoc;
    var saveAmount = oldPrice > basePrice ? oldPrice - basePrice : 0;
    var allImages = Model.HinhAnhSanPhams?.ToList() ?? new System.Collections.Generic.List<Doanh2026.Models.HinhAnhSanPham>();
    var mainImg = allImages.FirstOrDefault(h => h.LaAnhDaiDien == true)?.DuongDanAnh
        ?? allImages.FirstOrDefault()?.DuongDanAnh
        ?? "https://via.placeholder.com/600x500?text=No+Image";
}

<div class="text-[13px] text-gray-500 mb-4 px-2">
    Trang chủ &rsaquo;
    <a href="/Product/Category/@(Model.MaDanhMuc ?? 0)" class="hover:text-pcm-blue transition">@(Model.DanhMuc?.TenDanhMuc ?? "Sản phẩm")</a>
</div>

<div class="bg-white p-4 md:p-6 rounded-md shadow-sm border border-gray-100 mb-8">
    <div class="flex flex-col lg:flex-row gap-8">
        <div class="w-full lg:w-5/12">
            <div class="border border-gray-100 rounded mb-4 overflow-hidden relative group bg-white">
                <img src="@mainImg" alt="@Model.TenSanPham" class="w-full object-contain transform group-hover:scale-105 transition duration-500 h-[400px]" id="main-product-img">
            </div>

            @if (allImages.Count > 0)
            {
                <div class="grid grid-cols-5 gap-2">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        var img = allImages[i];
                        <button type="button" class="border-2 @(i == 0 ? "border-pcm-blue" : "border-gray-200") rounded overflow-hidden hover:border-pcm-blue transition thumbnail-item" onclick="switchImage('@img.DuongDanAnh', this)">
                            <img src="@img.DuongDanAnh" class="w-full h-14 object-cover" />
                        </button>
                    }
                </div>
            }
        </div>

        <div class="w-full lg:w-7/12">
            <h1 class="text-2xl font-bold text-gray-800 mb-4 uppercase leading-tight">@Model.TenSanPham</h1>

            <div class="bg-[#d52b36] rounded-md p-4 mb-5 flex flex-col md:flex-row md:items-center justify-between text-white relative shadow-md">
                <div class="flex items-end gap-4 z-10">
                    <span class="text-3xl font-extrabold tracking-tight" id="current-price" data-base="@basePrice.ToString(System.Globalization.CultureInfo.InvariantCulture)">@basePrice.ToString("N0")<sup class="text-sm">đ</sup></span>
                    @if (saveAmount > 0)
                    {
                        <span class="text-lg line-through opacity-80 mb-1 font-medium">@oldPrice.ToString("N0")<sup class="text-xs">VNĐ</sup></span>
                    }
                </div>
                <div class="text-sm mt-3 md:mt-0 font-medium z-10 px-3 py-1.5 bg-white/20 rounded shadow-inner" id="upgrade-summary">Nâng cấp: 0đ</div>
            </div>

            <div class="border border-gray-200 rounded mb-6 overflow-hidden shadow-sm">
                <div class="bg-gray-50 flex items-center p-3 border-b border-gray-200 font-bold text-[13px] text-gray-700">
                    <i class="fas fa-cogs text-red-500 mr-2 text-lg"></i> UPGRADE
                </div>
                <div class="p-4 space-y-5">
                    <div class="flex items-start flex-wrap md:flex-nowrap">
                        <div class="w-full md:w-28 text-[13px] font-semibold text-gray-700 mt-2 mb-2 md:mb-0">RAM</div>
                        <div class="flex-1 flex flex-wrap gap-2 upgrade-group" data-group="ram">
                            <button type="button" class="upgrade-option is-active border-2 border-pcm-blue text-pcm-blue bg-blue-50 px-3 py-1.5 text-[13px] font-bold rounded transition" data-extra="0">RAM 16GB DDR5</button>
                            <button type="button" class="upgrade-option border border-gray-300 text-gray-600 px-3 py-1.5 text-[13px] rounded transition" data-extra="1200000">RAM 32GB DDR5 (+1.200.000đ)</button>
                        </div>
                    </div>
                    <div class="flex items-start flex-wrap md:flex-nowrap">
                        <div class="w-full md:w-28 text-[13px] font-semibold text-gray-700 mt-2 mb-2 md:mb-0">SSD</div>
                        <div class="flex-1 flex flex-wrap gap-2 upgrade-group" data-group="ssd">
                            <button type="button" class="upgrade-option is-active border-2 border-pcm-blue text-pcm-blue bg-blue-50 px-3 py-1.5 text-[13px] font-bold rounded transition" data-extra="0">SSD 512GB</button>
                            <button type="button" class="upgrade-option border border-gray-300 text-gray-600 px-3 py-1.5 text-[13px] rounded transition" data-extra="900000">SSD 1TB (+900.000đ)</button>
                        </div>
                    </div>
                    <div class="flex items-start flex-wrap md:flex-nowrap">
                        <div class="w-full md:w-28 text-[13px] font-semibold text-gray-700 mt-2 mb-2 md:mb-0">Tản nhiệt</div>
                        <div class="flex-1 flex flex-wrap gap-2 upgrade-group" data-group="cooling">
                            <button type="button" class="upgrade-option is-active border-2 border-pcm-blue text-pcm-blue bg-blue-50 px-3 py-1.5 text-[13px] font-bold rounded transition" data-extra="0">Tản nhiệt khí</button>
                            <button type="button" class="upgrade-option border border-gray-300 text-gray-600 px-3 py-1.5 text-[13px] rounded transition" data-extra="1500000">AIO 240 (+1.500.000đ)</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 mt-8">
                <button type="button" onclick="buyNow(@Model.MaSanPham)" class="flex-1 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-md py-3 font-bold hover:shadow-lg hover:from-red-600 hover:to-red-700 transition flex flex-col justify-center items-center shadow-md shadow-red-500/30">
                    <span class="text-lg uppercase tracking-wide">Mua ngay</span>
                    <span class="text-[11px] font-normal mt-0.5">Thêm vào giỏ và chuyển sang thanh toán</span>
                </button>
                <div class="flex sm:w-[180px] gap-2 h-[64px] sm:h-auto">
                    <button type="button" onclick="addToCart(@Model.MaSanPham)" id="btnAddToCart" class="w-full border-2 border-pcm-blue text-pcm-blue bg-blue-50/50 rounded-md flex flex-col justify-center items-center hover:bg-pcm-blue hover:text-white transition group">
                        <i class="fas fa-cart-plus text-xl mb-1 group-hover:-translate-y-1 transition duration-300"></i>
                        <span class="text-[11px] font-bold uppercase">Thêm vào giỏ</span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="bg-white p-4 md:p-6 rounded-md shadow-sm border border-gray-100 mb-8 overflow-hidden">
    <h2 class="text-xl font-bold uppercase text-gray-800 mt-2 mb-4 border-b pb-2">Mô tả sản phẩm</h2>
    <div class="prose max-w-none text-gray-700 text-[14px] leading-relaxed ckeditor-content">
        @if (!string.IsNullOrEmpty(Model.MoTa))
        {
            @Html.Raw(Model.MoTa)
        }
        else
        {
            <div class="text-center py-8 opacity-50 bg-gray-50 rounded border border-dashed border-gray-300">
                <i class="fas fa-align-left text-4xl mb-3 text-gray-300 block"></i>
                <p>Thông tin mô tả đang được cập nhật...</p>
            </div>
        }
    </div>
</div>

<script>
    function switchImage(src, el) {
        document.getElementById('main-product-img').src = src;
        document.querySelectorAll('.thumbnail-item').forEach(function (t) {
            t.classList.remove('border-pcm-blue');
            t.classList.add('border-gray-200');
        });
        el.classList.remove('border-gray-200');
        el.classList.add('border-pcm-blue');
    }

    function formatVnMoney(value) {
        return new Intl.NumberFormat('vi-VN').format(value || 0) + 'đ';
    }

    function calcUpgradeTotal() {
        var total = 0;
        document.querySelectorAll('.upgrade-group').forEach(function (group) {
            var active = group.querySelector('.upgrade-option.is-active');
            if (!active) return;
            total += parseInt(active.dataset.extra || '0', 10);
        });
        return total;
    }

    function applyUpgradeStyles(group, selectedBtn) {
        group.querySelectorAll('.upgrade-option').forEach(function (btn) {
            btn.classList.remove('is-active', 'border-2', 'border-pcm-blue', 'text-pcm-blue', 'bg-blue-50', 'font-bold');
            btn.classList.add('border', 'border-gray-300', 'text-gray-600');
        });

        selectedBtn.classList.remove('border', 'border-gray-300', 'text-gray-600');
        selectedBtn.classList.add('is-active', 'border-2', 'border-pcm-blue', 'text-pcm-blue', 'bg-blue-50', 'font-bold');
    }

    function updateDisplayPrice() {
        var priceEl = document.getElementById('current-price');
        if (!priceEl) return;

        var base = parseInt(priceEl.dataset.base || '0', 10);
        var extra = calcUpgradeTotal();
        var finalPrice = base + extra;

        priceEl.innerHTML = formatVnMoney(finalPrice).replace('đ', '<sup class="text-sm">đ</sup>');
        var summary = document.getElementById('upgrade-summary');
        if (summary) summary.textContent = 'Nâng cấp: ' + formatVnMoney(extra);
    }

    function buyNow(productId) {
        $.post('/Cart/AddToCart', { productId: productId, quantity: 1 }, function (res) {
            if (res && res.success) {
                window.location.href = '/Payment/Checkout';
                return;
            }

            if (res && res.requireLogin) {
                Swal.fire({
                    icon: 'info',
                    title: 'Chưa đăng nhập',
                    text: res.message || 'Vui lòng đăng nhập để tiếp tục.',
                    showCancelButton: true,
                    confirmButtonText: 'Đăng nhập',
                    cancelButtonText: 'Hủy',
                    confirmButtonColor: '#007cc2'
                }).then(function (r) {
                    if (r.isConfirmed && typeof openAuthModal === 'function') openAuthModal('login');
                });
                return;
            }

            Swal.fire({ icon: 'error', title: 'Lỗi', text: (res && res.message) ? res.message : 'Không thể mua ngay.' });
        }).fail(function () {
            Swal.fire({ icon: 'error', title: 'Lỗi hệ thống', text: 'Không thể kết nối tới máy chủ.' });
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('.upgrade-group').forEach(function (group) {
            group.querySelectorAll('.upgrade-option').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    applyUpgradeStyles(group, btn);
                    updateDisplayPrice();
                });
            });
        });

        updateDisplayPrice();
    });
</script>

<style>
    .ckeditor-content h1, .ckeditor-content h2, .ckeditor-content h3 { font-weight: bold; margin-bottom: .5em; margin-top: 1em; color: #1f2937; }
    .ckeditor-content h2 { font-size: 1.5rem; }
    .ckeditor-content h3 { font-size: 1.25rem; }
    .ckeditor-content p { margin-bottom: 1em; }
    .ckeditor-content ul { list-style-type: disc; padding-left: 2rem; margin-bottom: 1em; }
    .ckeditor-content ol { list-style-type: decimal; padding-left: 2rem; margin-bottom: 1em; }
    .ckeditor-content strong { font-weight: 700; color: #111827; }
    .ckeditor-content img { max-width: 100%; height: auto; border-radius: 4px; margin: 1em auto; }
    .ckeditor-content a { color: #007cc2; text-decoration: underline; }
</style>
