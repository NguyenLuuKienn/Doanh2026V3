@model Doanh2026.Models.SanPham
@{
    ViewBag.Title = Model.TenSanPham;
    Layout = "~/Views/Shared/_LayoutIndex.cshtml";
    
    var price = Model.GiaUuDai ?? Model.GiaGoc;
    var oldPrice = Model.GiaGoc;
    var saveAmount = oldPrice > price ? oldPrice - price : 0;
    
    // Xử lý chuỗi thông số kỹ thuật (xuống dòng bằng thẻ li)
    var thuocTinhs = string.IsNullOrEmpty(Model.ThongSoKyThuat) ? new string[] { } : Model.ThongSoKyThuat.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
}

<div class="text-[13px] text-gray-500 mb-4 px-2">
    Trang chủ &rsaquo; <a href="#" class="hover:text-pcm-blue transition">@(Model.DanhMuc?.TenDanhMuc ?? "Sản phẩm")</a>
</div>

<div class="bg-white p-4 md:p-6 rounded-md shadow-sm border border-gray-100 mb-8">
    <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- Left: Image Gallery -->
        <div class="w-full lg:w-5/12">
            @{
                var allImages = Model.HinhAnhSanPhams?.ToList() ?? new System.Collections.Generic.List<Doanh2026.Models.HinhAnhSanPham>();
                var mainImg = allImages.FirstOrDefault(h => h.LaAnhDaiDien == true)?.DuongDanAnh 
                              ?? allImages.FirstOrDefault()?.DuongDanAnh 
                              ?? "https://via.placeholder.com/600x500?text=No+Image";
                int totalImgs = allImages.Count;
            }
            <div class="border border-gray-100 rounded mb-4 overflow-hidden relative group bg-white">
                <img src="@mainImg" alt="@Model.TenSanPham" class="w-full object-contain cursor-crosshair transform group-hover:scale-105 transition duration-500 h-[400px]" id="main-product-img">
                @if (totalImgs > 1) {
                    <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 bg-black/60 text-white text-[10px] px-3 py-1 rounded-full" id="img-counter">1 / @totalImgs</div>
                }
            </div>
            
            @if (allImages.Count > 0)
            {
                <div class="grid grid-cols-5 gap-2">
                    @for (int i = 0; i < allImages.Count; i++)
                    {
                        var img = allImages[i];
                        var isFirst = i == 0;
                        <div class="border-2 @(isFirst ? "border-pcm-blue" : "border-gray-200") rounded overflow-hidden cursor-pointer hover:border-pcm-blue transition thumbnail-item" onclick="switchImage('@img.DuongDanAnh', this, @(i + 1), @totalImgs)">
                            <img src="@img.DuongDanAnh" class="w-full h-14 object-cover" />
                        </div>
                    }
                </div>
            }
            
            <div class="mt-6 text-center">
                <button class="border border-red-500 text-red-500 hover:bg-red-50 px-4 py-1.5 rounded-full text-[13px] font-semibold transition">
                    Sản phẩm mua kèm
                </button>
            </div>
        </div>

        <script>
            function switchImage(src, el, idx, total) {
                document.getElementById('main-product-img').src = src;
                var counter = document.getElementById('img-counter');
                if(counter) counter.textContent = idx + ' / ' + total;
                // Update border active
                document.querySelectorAll('.thumbnail-item').forEach(function(t) {
                    t.classList.remove('border-pcm-blue');
                    t.classList.add('border-gray-200');
                });
                el.classList.remove('border-gray-200');
                el.classList.add('border-pcm-blue');
            }
        </script>

        <!-- Right: Product Info -->
        <div class="w-full lg:w-7/12">
            <h1 class="text-2xl font-bold text-gray-800 mb-4 uppercase leading-tight">@Model.TenSanPham</h1>
            
            <!-- Price Box -->
            <div class="bg-[#d52b36] rounded-md p-4 mb-5 flex flex-col md:flex-row md:items-center justify-between text-white relative shadow-md">
                <div class="flex items-end gap-4 z-10">
                    <span class="text-3xl font-extrabold tracking-tight">@price.ToString("N0")<sup class="text-sm">đ</sup></span>
                    @if (saveAmount > 0)
                    {
                        <span class="text-lg line-through opacity-80 mb-1 font-medium">@oldPrice.ToString("N0")<sup class="text-xs">VNĐ</sup></span>
                    }
                </div>
                @if (saveAmount > 0)
                {
                    <div class="text-sm mt-3 md:mt-0 font-medium z-10 px-3 py-1.5 bg-white/20 rounded shadow-inner">Tiết kiệm: @saveAmount.ToString("N0")<sup class="text-[10px]">VNĐ</sup></div>
                }
            </div>

            <!-- Badges -->
            <div class="flex flex-wrap gap-2 md:gap-4 mb-6">
                <span class="bg-yellow-100 text-yellow-800 border border-yellow-300/50 px-3 py-1.5 rounded text-[13px] font-bold tracking-wide shadow-sm">Bảo hành: 36 Tháng</span>
                <button class="bg-blue-600 text-white px-5 py-1.5 rounded-full text-[13px] font-bold shadow-md hover:bg-blue-700 hover:shadow-lg transition flex items-center">
                    <i class="fas fa-share-alt mr-2"></i> TƯ VẤN NÂNG CẤP
                </button>
            </div>

            <!-- Thông số kỹ thuật (Loại bỏ tại vị trí Left bên Cạnh Giá, chuyển xuống dưới Tương Đương UI Mẫu) -->
            <!-- Xem khối <div class="mt-8"> ở dưới -->

            <!-- Configuration / Upgrade -->
            <div class="border border-gray-200 rounded mb-6 overflow-hidden shadow-sm">
                <div class="bg-gray-50 flex items-center p-3 border-b border-gray-200 font-bold text-[13px] text-gray-700">
                    <i class="fas fa-cogs text-red-500 mr-2 text-lg"></i> UPGRADE
                </div>
                <div class="p-4 space-y-5">
                    <!-- Config RAM -->
                    <div class="flex items-start flex-wrap md:flex-nowrap">
                        <div class="w-full md:w-28 text-[13px] font-semibold text-gray-700 mt-2 mb-2 md:mb-0">RAM</div>
                        <div class="flex-1 flex flex-wrap gap-2">
                            <label class="cursor-pointer">
                                <input type="radio" name="ram" class="peer hidden" checked>
                                <div class="border-2 border-pcm-blue text-pcm-blue bg-blue-50 px-3 py-1.5 text-[13px] font-bold rounded transition relative pr-7 shadow-sm">
                                    RAM 16GB DDR5
                                    <div class="absolute -top-2 -right-2 bg-pcm-blue text-white rounded-full w-5 h-5 flex items-center justify-center text-[10px] shadow"><i class="fas fa-check"></i></div>
                                </div>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="ram" class="peer hidden">
                                <div class="border border-gray-300 text-gray-600 px-4 py-1.5 text-[13px] font-medium hover:border-pcm-blue hover:text-pcm-blue rounded transition">
                                    Ram 32GB DDR5
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Config SSD -->
                    <div class="flex items-start flex-wrap md:flex-nowrap">
                        <div class="w-full md:w-28 text-[13px] font-semibold text-gray-700 mt-2 mb-2 md:mb-0">Ổ cứng SSD</div>
                        <div class="flex-1 flex flex-wrap gap-2">
                            <label class="cursor-pointer">
                                <input type="radio" name="ssd" class="peer hidden" checked>
                                <div class="border-2 border-pcm-blue text-pcm-blue bg-blue-50 px-3 py-1.5 text-[13px] font-bold rounded transition relative pr-7 shadow-sm">
                                    SSD 512GB
                                    <div class="absolute -top-2 -right-2 bg-pcm-blue text-white rounded-full w-5 h-5 flex items-center justify-center text-[10px] shadow"><i class="fas fa-check"></i></div>
                                </div>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="ssd" class="peer hidden">
                                <div class="border border-gray-300 text-gray-600 px-4 py-1.5 text-[13px] font-medium hover:border-pcm-blue hover:text-pcm-blue rounded transition">
                                    SSD 1TB
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Config Cooling -->
                    <div class="flex items-start flex-wrap md:flex-nowrap">
                        <div class="w-full md:w-28 text-[13px] font-semibold text-gray-700 mt-2 mb-2 md:mb-0">Tản nhiệt</div>
                        <div class="flex-1 flex flex-wrap gap-2">
                            <label class="cursor-pointer">
                                <input type="radio" name="cooling" class="peer hidden" checked>
                                <div class="border-2 border-pcm-blue text-pcm-blue bg-blue-50 px-3 py-1.5 text-[13px] font-bold rounded transition relative pr-7 shadow-sm">
                                    Tản nhiệt Khí
                                    <div class="absolute -top-2 -right-2 bg-pcm-blue text-white rounded-full w-5 h-5 flex items-center justify-center text-[10px] shadow"><i class="fas fa-check"></i></div>
                                </div>
                            </label>
                            <label class="cursor-pointer">
                                <input type="radio" name="cooling" class="peer hidden">
                                <div class="border border-gray-300 text-gray-600 px-4 py-1.5 text-[13px] font-medium hover:border-pcm-blue hover:text-pcm-blue rounded transition">
                                    Tản nhiệt nước AIO 240
                                </div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Promotions -->
            <div class="border border-red-200 rounded mb-6 overflow-hidden shadow-sm">
                <div class="bg-red-50 flex items-center p-3 border-b border-red-200 font-bold text-[13px] text-red-600">
                    <i class="fas fa-gift mr-2 text-lg"></i> KHUYẾN MÃI
                </div>
                <div class="p-4 text-[13px] text-gray-700 bg-red-50/30">
                    <div class="flex items-start mb-3">
                        <div class="w-5 h-5 bg-red-500 text-white rounded-full flex items-center justify-center text-[11px] mr-3 flex-shrink-0 mt-0.5 font-bold shadow-sm">1</div>
                        <p class="leading-relaxed">Tặng Phiếu mua hàng trị giá <span class="text-red-600 font-bold">500.000đ</span> (áp dụng khi build kèm màn hình Máy tính)</p>
                    </div>
                    <div class="flex items-start mb-1">
                        <div class="w-5 h-5 bg-red-500 text-white rounded-full flex items-center justify-center text-[11px] mr-3 flex-shrink-0 mt-0.5 font-bold shadow-sm">2</div>
                        <p class="leading-relaxed">Tặng Combo Phím Chuột Cao cấp hoặc Tai nghe Gaming chất lượng cao.</p>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-3 mt-8">
                <button type="button" class="flex-1 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-md py-3 font-bold hover:shadow-lg hover:from-red-600 hover:to-red-700 transition flex flex-col justify-center items-center shadow-md shadow-red-500/30">
                    <span class="text-lg uppercase tracking-wide">Mua ngay</span>
                    <span class="text-[11px] font-normal mt-0.5">Giao tận nơi hoặc nhận tại cửa hàng</span>
                </button>
                <div class="flex sm:w-[180px] gap-2 h-[64px] sm:h-auto">
                    <button type="button" onclick="addToCart(@Model.MaSanPham)" id="btnAddToCart" class="w-full border-2 border-pcm-blue text-pcm-blue bg-blue-50/50 rounded-md flex flex-col justify-center items-center hover:bg-pcm-blue hover:text-white transition group">
                        <i class="fas fa-cart-plus text-xl mb-1 group-hover:-translate-y-1 transition duration-300"></i>
                        <span class="text-[11px] font-bold uppercase">Thêm vào giỏ</span>
                    </button>
                </div>


            </div>

        </div>
    </div>
</div>

<!-- ============================================== -->
<!-- PHẦN DƯỚI: THÔNG SỐ KỸ THUẬT (TABLE) & MÔ TẢ (HTML) -->
<!-- ============================================== -->
<div class="bg-white p-4 md:p-6 rounded-md shadow-sm border border-gray-100 mb-8 overflow-hidden">
    
    <!-- THÔNG SỐ KỸ THUẬT (DẠNG BẢNG MẪU) -->
    @if (!string.IsNullOrEmpty(Model.ThongSoKyThuat))
    {
        <h2 class="text-xl font-bold uppercase text-gray-800 mb-4 pb-2">Thông số kỹ thuật</h2>
        <div class="mb-8 border border-gray-200 rounded overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-center border-collapse">
                    <thead>
                        <tr class="bg-white text-gray-600 border-b border-gray-200 uppercase text-[12px]">
                            <th class="py-3 px-4 w-16 border-r border-gray-200 font-medium">STT</th>
                            <th class="py-3 px-4 text-center border-r border-gray-200 font-medium whitespace-nowrap">Mô tả thiết bị / Tính năng</th>
                            <th class="py-3 px-4 w-20 border-r border-gray-200 font-medium">SL</th>
                            <th class="py-3 px-4 w-24 font-medium">Bảo hành</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 font-medium">
                        @{
                            int stt = 1;
                            try {
                                var specsDict = Newtonsoft.Json.JsonConvert.DeserializeObject<System.Collections.Generic.Dictionary<string, string>>(Model.ThongSoKyThuat);
                                foreach(var kvp in specsDict) {
                                    <tr class="@(stt % 2 == 0 ? "bg-gray-50" : "bg-white") border-b border-gray-100 hover:bg-gray-100 transition">
                                        <td class="py-3 px-4 border-r border-gray-200">@stt</td>
                                        <td class="py-3 px-4 text-center border-r border-gray-200">
                                            <span class="font-bold text-gray-800 mr-1 uppercase">@kvp.Key:</span> @kvp.Value
                                        </td>
                                        <td class="py-3 px-4 border-r border-gray-200">1</td>
                                        <td class="py-3 px-4">36th</td>
                                    </tr>
                                    stt++;
                                }
                            } 
                            catch (Exception) {
                                // Handle dạng list text thường fallback
                                var specs = Model.ThongSoKyThuat.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
                                foreach (var spec in specs)
                                {
                                    <tr class="@(stt % 2 == 0 ? "bg-gray-50" : "bg-white") border-b border-gray-100">
                                        <td class="py-3 px-4 border-r border-gray-200">@stt</td>
                                        <td class="py-3 px-4 text-center border-r border-gray-200">@spec</td>
                                        <td class="py-3 px-4 border-r border-gray-200">1</td>
                                        <td class="py-3 px-4">36th</td>
                                    </tr>
                                    stt++;
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="bg-gray-50/50 flex justify-center py-3 border-t border-gray-200">
                <button class="text-pcm-blue text-[13px] font-bold uppercase transition hover:text-blue-800 tracking-wide">Thu Gọn <i class="fas fa-chevron-up ml-1 text-[10px]"></i></button>
            </div>
        </div>
    }

    <!-- MÔ TẢ SẢN PHẨM (CKEDITOR HTML RENDER) -->
    <h2 class="text-xl font-bold uppercase text-gray-800 mt-8 mb-4 border-b pb-2">Mô Tả Sản Phẩm</h2>
    
    <div class="prose max-w-none text-gray-700 text-[14px] leading-relaxed ckeditor-content">
        @if (!string.IsNullOrEmpty(Model.MoTa))
        {
            @Html.Raw(Model.MoTa)
        }
        else
        {
            <div class="text-center py-8 opacity-50 bg-gray-50 rounded border border-dashed border-gray-300">
                <i class="fas fa-align-left text-4xl mb-3 text-gray-300 block"></i>
                <p>Thông tin mô tả đang được cập nhật...</p>
            </div>
        }
    </div>
    
    <style>
        .ckeditor-content h1, .ckeditor-content h2, .ckeditor-content h3 { font-weight: bold; margin-bottom: 0.5em; margin-top: 1em; color: #1f2937; }
        .ckeditor-content h2 { font-size: 1.5rem; }
        .ckeditor-content h3 { font-size: 1.25rem; }
        .ckeditor-content p { margin-bottom: 1em; }
        .ckeditor-content ul { list-style-type: disc; padding-left: 2rem; margin-bottom: 1em; }
        .ckeditor-content ol { list-style-type: decimal; padding-left: 2rem; margin-bottom: 1em; }
        .ckeditor-content strong { font-weight: 700; color: #111827; }
        .ckeditor-content img { max-width: 100%; height: auto; border-radius: 4px; margin: 1em auto; }
        .ckeditor-content a { color: #007cc2; text-decoration: underline; }
    </style>
</div>
