@model Doanh2026.Models.NguoiDung
@{
    ViewBag.Title = "Thông tin cá nhân";
    Layout = "~/Views/Shared/_LayoutIndex.cshtml";
}

<div class="mb-6 text-[13px] text-gray-500">
    Trang chủ &rsaquo; <span class="font-medium text-gray-700">Thông tin cá nhân</span>
</div>

<div class="max-w-4xl mx-auto">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="bg-pcm-blue px-8 py-10 text-white relative">
            <div class="relative z-10 flex flex-col md:flex-row items-center gap-6">
                <div class="w-24 h-24 bg-white/20 rounded-full flex items-center justify-center border-4 border-white/30 shadow-xl">
                    <i class="fas fa-user text-4xl"></i>
                </div>
                <div class="text-center md:text-left">
                    <h1 class="text-3xl font-extrabold mb-1">@Model.HoTen</h1>
                    <p class="text-blue-100 flex items-center justify-center md:justify-start">
                        <i class="fas fa-envelope mr-2 opacity-70"></i> @Model.Email
                    </p>
                </div>
                <div class="md:ml-auto mt-4 md:mt-0">
                    <button type="button" onclick="openProfileEditModal()" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white text-pcm-blue font-bold shadow-lg hover:bg-blue-50 transition">
                        <i class="fas fa-pen"></i> Chỉnh sửa thông tin
                    </button>
                </div>
            </div>
            <!-- Decor -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32 blur-3xl"></div>
        </div>

        <div class="p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Info Section -->
                <div class="space-y-6">
                    <h2 class="text-lg font-bold text-gray-800 border-l-4 border-pcm-blue pl-3">Thông tin tài khoản</h2>
                    
                    <div class="space-y-4">
                        <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <i class="fas fa-phone-alt mt-1 text-pcm-blue bg-blue-50 w-8 h-8 rounded-lg flex items-center justify-center"></i>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Số điện thoại</p>
                                <p class="text-gray-800 font-semibold mt-0.5">@Model.SoDienThoai</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <i class="fas fa-map-marker-alt mt-1 text-red-400 bg-red-50 w-8 h-8 rounded-lg flex items-center justify-center"></i>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Địa chỉ nhận hàng</p>
                                <p class="text-gray-800 font-semibold mt-0.5">@Model.DiaChi</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
                            <i class="fas fa-calendar-alt mt-1 text-green-400 bg-green-50 w-8 h-8 rounded-lg flex items-center justify-center"></i>
                            <div>
                                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider">Ngày tham gia</p>
                                <p class="text-gray-800 font-semibold mt-0.5">@(Model.NgayDangKy?.ToString("dd/MM/yyyy") ?? "N/A")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Shortcuts Section -->
                <div>
                    <h2 class="text-lg font-bold text-gray-800 border-l-4 border-pcm-blue pl-3 mb-6">Quản lý nâng cao</h2>
                    <div class="grid grid-cols-1 gap-3">
                        <a href="/Account/MyOrders" class="flex items-center justify-between p-4 rounded-xl border border-gray-200 hover:border-pcm-blue hover:bg-blue-50 transition group">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-box-open text-pcm-blue text-lg"></i>
                                <span class="font-bold text-gray-700 group-hover:text-pcm-blue">Lịch sử đơn hàng</span>
                            </div>
                            <i class="fas fa-chevron-right text-gray-300 group-hover:text-pcm-blue transition"></i>
                        </a>

                        <a href="/Cart/Index" class="flex items-center justify-between p-4 rounded-xl border border-gray-200 hover:border-pcm-blue hover:bg-blue-50 transition group">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-shopping-cart text-pcm-blue text-lg"></i>
                                <span class="font-bold text-gray-700 group-hover:text-pcm-blue">Giỏ hàng của tôi</span>
                            </div>
                            <i class="fas fa-chevron-right text-gray-300 group-hover:text-pcm-blue transition"></i>
                        </a>

                        <button onclick="Swal.fire('Tính năng đang phát triển', 'Chức năng đổi mật khẩu sẽ sớm ra mắt!', 'info')" class="flex items-center justify-between p-4 rounded-xl border border-gray-200 hover:border-pcm-blue hover:bg-blue-50 transition group w-full text-left">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-lock text-pcm-blue text-lg"></i>
                                <span class="font-bold text-gray-700 group-hover:text-pcm-blue">Đổi mật khẩu</span>
                            </div>
                            <i class="fas fa-chevron-right text-gray-300 group-hover:text-pcm-blue transition"></i>
                        </button>
                    </div>

                    <a href="/Account/Logout" class="mt-10 flex items-center justify-center gap-2 w-full py-4 text-red-500 font-bold border-2 border-red-100 rounded-xl hover:bg-red-50 hover:border-red-200 transition">
                        <i class="fas fa-sign-out-alt"></i> Đăng xuất tài khoản
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Profile Edit Modal -->
<div id="profileEditModal" class="fixed inset-0 z-[300] hidden overflow-y-auto">
    <button type="button" class="fixed inset-0 bg-slate-900/70 backdrop-blur-sm" onclick="closeProfileEditModal()" aria-label="Đóng chỉnh sửa thông tin"></button>
    <div class="min-h-screen px-4 text-center flex items-center justify-center">
        <div id="profileEditDialog" class="inline-block w-full max-w-xl bg-white rounded-2xl shadow-2xl text-left overflow-hidden transform scale-95 opacity-0 transition-all relative z-10">
            <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-gray-50">
                <div>
                    <h3 class="text-lg font-bold text-gray-800">Chỉnh sửa thông tin cá nhân</h3>
                    <p class="text-xs text-gray-500 mt-1">Cập nhật tên, số điện thoại và địa chỉ nhận hàng</p>
                </div>
                <button type="button" onclick="closeProfileEditModal()" class="text-gray-400 hover:text-red-500 text-xl leading-none">&times;</button>
            </div>

            <form id="profileEditForm" class="p-6 space-y-4" onsubmit="submitProfileEdit(event)">
                <div>
                    <label for="editHoTen" class="block text-xs font-bold text-gray-600 mb-1.5 uppercase">Họ &amp; Tên <span class="text-red-500">*</span></label>
                    <input type="text" id="editHoTen" name="hoTen" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:border-pcm-blue focus:ring-1 focus:ring-pcm-blue outline-none" value="@Model.HoTen" required />
                </div>
                <div>
                    <label for="editSoDienThoai" class="block text-xs font-bold text-gray-600 mb-1.5 uppercase">Số điện thoại <span class="text-red-500">*</span></label>
                    <input type="tel" id="editSoDienThoai" name="soDienThoai" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:border-pcm-blue focus:ring-1 focus:ring-pcm-blue outline-none" value="@Model.SoDienThoai" required />
                </div>
                <div>
                    <label for="editDiaChi" class="block text-xs font-bold text-gray-600 mb-1.5 uppercase">Địa chỉ <span class="text-red-500">*</span></label>
                    <textarea id="editDiaChi" name="diaChi" rows="3" class="w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:border-pcm-blue focus:ring-1 focus:ring-pcm-blue outline-none" required>@Model.DiaChi</textarea>
                </div>

                <div class="flex items-center justify-end gap-2 pt-2">
                    <button type="button" onclick="closeProfileEditModal()" class="px-4 py-2 rounded-lg bg-gray-100 text-gray-700 font-semibold hover:bg-gray-200 transition">Hủy</button>
                    <button type="submit" id="btnSaveProfile" class="px-4 py-2 rounded-lg bg-pcm-blue text-white font-semibold hover:bg-blue-800 transition">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section scripts {
<script>
    function openProfileEditModal() {
        const modal = document.getElementById('profileEditModal');
        const dialog = document.getElementById('profileEditDialog');
        modal.classList.remove('hidden');
        setTimeout(() => {
            dialog.classList.remove('scale-95', 'opacity-0');
            dialog.classList.add('scale-100', 'opacity-100');
        }, 10);
    }

    function closeProfileEditModal() {
        const modal = document.getElementById('profileEditModal');
        const dialog = document.getElementById('profileEditDialog');
        dialog.classList.remove('scale-100', 'opacity-100');
        dialog.classList.add('scale-95', 'opacity-0');
        setTimeout(() => modal.classList.add('hidden'), 180);
    }

    function submitProfileEdit(event) {
        event.preventDefault();

        const data = {
            hoTen: $('#editHoTen').val().trim(),
            soDienThoai: $('#editSoDienThoai').val().trim(),
            diaChi: $('#editDiaChi').val().trim()
        };

        if (!data.hoTen || !data.soDienThoai || !data.diaChi) {
            Toast.fire({ icon: 'warning', title: 'Vui lòng nhập đầy đủ thông tin.' });
            return;
        }

        $('#btnSaveProfile').prop('disabled', true).text('Đang lưu...');

        $.post('/Account/UpdateProfile', data, function (res) {
            if (res.success) {
                Toast.fire({ icon: 'success', title: res.message });
                closeProfileEditModal();
                setTimeout(() => location.reload(), 800);
            } else {
                Swal.fire({ icon: 'error', title: 'Cập nhật thất bại', text: res.message });
            }
        }).fail(function () {
            Swal.fire({ icon: 'error', title: 'Lỗi hệ thống', text: 'Không thể cập nhật thông tin cá nhân.' });
        }).always(function () {
            $('#btnSaveProfile').prop('disabled', false).text('Lưu thay đổi');
        });
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeProfileEditModal();
    });
</script>
}
