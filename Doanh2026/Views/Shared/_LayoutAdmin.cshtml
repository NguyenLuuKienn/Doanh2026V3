<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Quản trị hệ thống QuốcDoanhJr</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'pcm-blue': '#007cc2',
                        'admin-dark': '#1e293b',
                        'admin-hover': '#334155',
                        'admin-active': '#0f172a'
                    }
                }
            }
        }
    </script>
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js for Admin dashboard -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f1f5f9; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="flex h-screen overflow-hidden">
    
    <!-- Sidebar Overlay (Mobile) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-slate-900/50 z-40 hidden md:hidden" onclick="toggleAdminSidebar()"></div>

    <!-- Sidebar -->
    <aside id="admin-sidebar" class="fixed inset-y-0 left-0 z-50 w-[260px] bg-admin-dark text-slate-300 flex flex-col shrink-0 transition-all duration-300 overflow-y-auto transform -translate-x-full md:translate-x-0 md:static">
        <!-- Logo -->
        <div class="h-16 flex items-center justify-center border-b border-slate-700/50 px-4 shrink-0 bg-admin-active">
            <a href="/Admin" class="text-xl font-black tracking-tighter flex items-center text-white">
                <i class="fas fa-desktop text-pcm-blue mr-2"></i>
                QuốcDoanh<span class="text-pcm-blue mx-1">Jr</span><span class="text-[10px] uppercase text-slate-400 font-medium">ADMIN</span>
            </a>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto">
            <p class="px-2 text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 mt-2">Quản lý</p>
            
            <a href="/Admin/Index" class="flex items-center px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white @(ViewContext.RouteData.Values["controller"].ToString() == "Admin" && ViewContext.RouteData.Values["action"].ToString() == "Index" ? "bg-pcm-blue text-white shadow-md shadow-pcm-blue/20" : "")">
                <i class="fas fa-chart-pie w-6 text-center mr-1 @(ViewContext.RouteData.Values["controller"].ToString() == "Admin" ? "text-white" : "text-slate-400")"></i>
                <span>Dashboard</span>
            </a>
            
            <a href="/AdminProduct/Index" class="flex items-center justify-between px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white group @(ViewContext.RouteData.Values["controller"].ToString() == "AdminProduct" ? "bg-admin-hover text-white" : "")">
                <div class="flex items-center">
                    <i class="fas fa-box w-6 text-center mr-1 text-slate-400 group-hover:text-white transition"></i>
                    <span>Sản phẩm</span>
                </div>
                <i class="fas fa-chevron-right text-[10px] opacity-50"></i>
            </a>

            <a href="/AdminCategory/Index" class="flex items-center justify-between px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white group @(ViewContext.RouteData.Values["controller"].ToString() == "AdminCategory" ? "bg-admin-hover text-white" : "")">
                <div class="flex items-center">
                    <i class="fas fa-tags w-6 text-center mr-1 text-slate-400 group-hover:text-white transition"></i>
                    <span>Danh mục</span>
                </div>
                <i class="fas fa-chevron-right text-[10px] opacity-50"></i>
            </a>

            <a href="/AdminCustomer/Index" class="flex items-center justify-between px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white group @(ViewContext.RouteData.Values["controller"].ToString() == "AdminCustomer" ? "bg-admin-hover text-white" : "")">
                <div class="flex items-center">
                    <i class="fas fa-users w-6 text-center mr-1 text-slate-400 group-hover:text-white transition"></i>
                    <span>Khách hàng</span>
                </div>
                <i class="fas fa-chevron-right text-[10px] opacity-50"></i>
            </a>

            <a href="/AdminStaff/Index" class="flex items-center justify-between px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white group @(ViewContext.RouteData.Values["controller"].ToString() == "AdminStaff" ? "bg-admin-hover text-white" : "")">
                <div class="flex items-center">
                    <i class="fas fa-user-tie w-6 text-center mr-1 text-slate-400 group-hover:text-white transition"></i>
                    <span>Nhân viên</span>
                </div>
                <i class="fas fa-chevron-right text-[10px] opacity-50"></i>
            </a>

            <p class="px-2 text-[10px] font-bold text-slate-500 uppercase tracking-wider mb-2 mt-5">Báo cáo</p>
            
            <a href="/Admin/Reports" class="flex items-center px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white group @(ViewContext.RouteData.Values["action"].ToString() == "Reports" ? "bg-admin-hover text-white" : "")">
                <i class="fas fa-chart-bar w-6 text-center mr-1 text-slate-400 group-hover:text-white"></i>
                <span>Thống kê doanh thu</span>
            </a>
            
            <a href="#" class="flex items-center px-3 py-2.5 rounded-lg text-[13px] font-medium transition hover:bg-admin-hover hover:text-white group">
                <i class="fas fa-cog w-6 text-center mr-1 text-slate-400 group-hover:text-white"></i>
                <span>Cài đặt chung</span>
            </a>
        </nav>
        
        <!-- User short info -->
        <div class="p-4 border-t border-slate-700/50">
            <div class="flex items-center gap-3">
                <img src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(Session["UserName"]?.ToString() ?? "Admin"))&background=007cc2&color=fff" class="w-9 h-9 rounded-md shadow-sm">
                <div class="flex-1 min-w-0">
                    <h4 class="text-[13px] font-bold text-white truncate">@(Session["UserName"] ?? "Admin")</h4>
                    <span class="text-[11px] text-green-400 flex items-center"><span class="w-1.5 h-1.5 bg-green-500 rounded-full mr-1 animate-pulse"></span>Online</span>
                </div>
                <a href="/Account/Logout" class="ml-auto text-slate-400 hover:text-white" title="Đăng xuất"><i class="fas fa-sign-out-alt"></i></a>
            </div>
        </div>
    </aside>

    <!-- Main Wrapper -->
    <div class="flex-1 flex flex-col h-screen overflow-hidden">
        
        <!-- Header -->
        <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 shrink-0 z-10 shadow-sm">
            <div class="flex items-center">
                <button onclick="toggleAdminSidebar()" class="md:hidden text-slate-500 hover:text-slate-800 text-xl mr-4 flex items-center justify-center">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="relative hidden sm:block">
                    <i class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-slate-400"></i>
                    <input type="text" placeholder="Tìm kiếm nhanh..." class="pl-10 pr-4 py-2 bg-slate-100 border-transparent rounded-lg text-sm focus:bg-white focus:border-pcm-blue focus:ring-2 focus:ring-pcm-blue/20 outline-none transition w-[300px]" />
                </div>
            </div>
            
            <div class="flex items-center space-x-4">
                <a href="/" target="_blank" class="text-slate-500 hover:text-pcm-blue text-sm font-medium mr-2 hidden sm:flex items-center transition">
                    <i class="fas fa-external-link-alt mr-1.5"></i> Xem Website
                </a>
                
                <div class="relative cursor-pointer text-slate-500 hover:text-slate-800 transition">
                    <i class="far fa-bell text-xl"></i>
                    <span class="absolute -top-1 -right-1.5 bg-red-500 text-white text-[9px] font-bold w-4 h-4 rounded-full flex items-center justify-center border-2 border-white">3</span>
                </div>
            </div>
        </header>

        <!-- Main Content Scrollable -->
        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-slate-50 p-6">
            @RenderBody()
        </main>
    </div>

    <script>
        function toggleAdminSidebar() {
            const sidebar = document.getElementById('admin-sidebar');
            const overlay = document.getElementById('sidebar-overlay');
            const isHidden = sidebar.classList.contains('-translate-x-full');
            
            if (isHidden) {
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
            } else {
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('hidden');
            }
        }
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
