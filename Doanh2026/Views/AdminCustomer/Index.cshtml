@model IEnumerable<Doanh2026.Models.NguoiDung>
@{
    ViewBag.Title = "Quản lý Khách hàng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="mb-6 flex flex-col sm:flex-row justify-between sm:items-center p-1">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Quản lý Khách hàng</h1>
        <p class="text-xs text-slate-500 mt-1">Danh sách toàn bộ khách hàng đã đăng ký trên hệ thống.</p>
    </div>
    <button onclick="openModal('create')" class="mt-4 sm:mt-0 bg-pcm-blue text-white px-4 py-2 rounded-md text-xs font-semibold shadow-md hover:bg-blue-700 transition flex items-center">
        <i class="fas fa-user-plus mr-1.5"></i> Thêm khách hàng
    </button>
</div>

<!-- Stats -->
<div class="grid grid-cols-3 gap-4 mb-5">
    <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100 flex items-center gap-3">
        <div class="w-10 h-10 bg-blue-100 text-pcm-blue rounded-lg flex items-center justify-center"><i class="fas fa-users"></i></div>
        <div><p class="text-xs text-slate-500">Tổng khách hàng</p><p class="text-xl font-black text-slate-800">@ViewBag.TotalCustomers</p></div>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100 flex items-center gap-3">
        <div class="w-10 h-10 bg-green-100 text-green-600 rounded-lg flex items-center justify-center"><i class="fas fa-check-circle"></i></div>
        <div><p class="text-xs text-slate-500">Đang hoạt động</p><p class="text-xl font-black text-slate-800">@ViewBag.ActiveCustomers</p></div>
    </div>
    <div class="bg-white rounded-xl p-4 shadow-sm border border-slate-100 flex items-center gap-3">
        <div class="w-10 h-10 bg-red-100 text-red-500 rounded-lg flex items-center justify-center"><i class="fas fa-ban"></i></div>
        <div><p class="text-xs text-slate-500">Bị khóa</p><p class="text-xl font-black text-slate-800">@ViewBag.LockedCustomers</p></div>
    </div>
</div>

<!-- Table -->
<div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
        <form action="/AdminCustomer/Index" method="get" class="relative">
            <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
            <input type="text" name="searchString" value="@ViewBag.SearchString" placeholder="Tìm tên, email, SĐT..." class="pl-9 pr-4 py-2 border border-slate-200 rounded-md text-sm focus:border-pcm-blue outline-none w-[280px]" />
            <button type="submit" class="hidden"></button>
        </form>
        <span class="text-xs text-slate-500 font-medium">@Model.Count() kết quả</span>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-slate-50 text-slate-500 text-[11px] uppercase tracking-wider">
                <tr>
                    <th class="py-3 px-5">Khách hàng</th>
                    <th class="py-3 px-5">Liên hệ</th>
                    <th class="py-3 px-5">Địa chỉ</th>
                    <th class="py-3 px-5 text-center">Trạng thái</th>
                    <th class="py-3 px-5">Ngày đăng ký</th>
                    <th class="py-3 px-5 text-center">Hành động</th>
                </tr>
            </thead>
            <tbody class="text-[13px] text-slate-700 divide-y divide-slate-100">
                @if (Model != null && Model.Any())
                {
                    foreach (var c in Model)
                    {
                        var isLocked = c.TrangThaiTaiKhoan == "KhoaTaiKhoan";
                        <tr class="hover:bg-slate-50 transition group">
                            <td class="py-3 px-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-gradient-to-br from-pcm-blue to-indigo-500 text-white flex items-center justify-center font-bold text-sm shrink-0">
                                        @(c.HoTen?.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <div class="font-semibold text-slate-800">@c.HoTen</div>
                                        <div class="text-[11px] text-slate-400">#@c.MaNguoiDung</div>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3 px-5">
                                <div class="font-medium text-pcm-blue">@c.Email</div>
                                <div class="text-[12px] text-slate-500">@c.SoDienThoai</div>
                            </td>
                            <td class="py-3 px-5 max-w-[180px] truncate text-slate-500 text-[12px]" title="@c.DiaChi">@c.DiaChi</td>
                            <td class="py-3 px-5 text-center">
                                @if (isLocked)
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-red-100 text-red-600">
                                        <i class="fas fa-lock mr-1 text-[10px]"></i> Bị khóa
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[11px] font-bold bg-emerald-100 text-emerald-700">
                                        <i class="fas fa-check mr-1 text-[10px]"></i> Hoạt động
                                    </span>
                                }
                            </td>
                            <td class="py-3 px-5 text-slate-500 text-[12px]">@c.NgayDangKy?.ToString("dd/MM/yyyy")</td>
                            <td class="py-3 px-5 text-center space-x-1">
                                <button onclick="openModal('edit', @c.MaNguoiDung)" class="w-7 h-7 rounded bg-slate-100 text-slate-500 hover:bg-amber-500 hover:text-white transition" title="Sửa"><i class="fas fa-edit text-xs"></i></button>
                                <button onclick="toggleStatus(@c.MaNguoiDung, '@c.HoTen')" class="w-7 h-7 rounded bg-slate-100 text-slate-500 @(isLocked ? "hover:bg-green-500" : "hover:bg-red-500") hover:text-white transition" title="@(isLocked ? "Mở khóa" : "Khóa")">
                                    <i class="fas @(isLocked ? "fa-lock-open" : "fa-ban") text-xs"></i>
                                </button>
                                <button onclick="deleteCustomer(@c.MaNguoiDung, '@c.HoTen')" class="w-7 h-7 rounded bg-slate-100 text-slate-500 hover:bg-red-500 hover:text-white transition" title="Xóa"><i class="fas fa-trash text-xs"></i></button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="6" class="py-10 text-center text-slate-400"><i class="fas fa-users text-3xl mb-2 block text-slate-200"></i>Không có khách hàng nào</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL CRUD -->
<div id="customerModal" class="fixed inset-0 z-[100] hidden overflow-y-auto">
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm" onclick="closeModal()"></div>
    <div class="min-h-screen px-4 flex items-center justify-center">
        <div class="inline-block w-full max-w-lg bg-white rounded-xl shadow-2xl text-left overflow-hidden transform scale-95 opacity-0 transition-all" id="modalDialog">
            <div class="flex justify-between items-center px-6 py-4 border-b bg-slate-50">
                <h3 class="text-base font-bold text-slate-800" id="modalTitle">Thêm Khách Hàng</h3>
                <button onclick="closeModal()" class="text-slate-400 hover:text-red-500"><i class="fas fa-times"></i></button>
            </div>
            <form id="customerForm" onsubmit="submitForm(event)" class="p-6 space-y-4">
                <input type="hidden" id="MaNguoiDung" name="MaNguoiDung" value="0" />
                <div class="grid grid-cols-2 gap-4">
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-600 mb-1">Họ & Tên <span class="text-red-500">*</span></label>
                        <input type="text" id="HoTen" name="HoTen" required class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm outline-none focus:border-pcm-blue" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-1">Email <span class="text-red-500">*</span></label>
                        <input type="email" id="Email" name="Email" required class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm outline-none focus:border-pcm-blue" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-1">Mật khẩu <span class="text-red-500" id="passRequired">*</span></label>
                        <input type="password" id="MatKhau" name="MatKhau" class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm outline-none focus:border-pcm-blue" placeholder="Để trống = không đổi (khi sửa)" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-1">Số điện thoại <span class="text-red-500">*</span></label>
                        <input type="tel" id="SoDienThoai" name="SoDienThoai" class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm outline-none focus:border-pcm-blue" />
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-600 mb-1">Trạng thái</label>
                        <select id="TrangThaiTaiKhoan" name="TrangThaiTaiKhoan" class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm outline-none bg-white focus:border-pcm-blue">
                            <option value="HoatDong">Hoạt động</option>
                            <option value="KhoaTaiKhoan">Bị khóa</option>
                        </select>
                    </div>
                    <div class="col-span-2">
                        <label class="block text-xs font-bold text-slate-600 mb-1">Địa chỉ</label>
                        <textarea id="DiaChi" name="DiaChi" rows="2" class="w-full px-3 py-2 border border-slate-200 rounded-md text-sm outline-none focus:border-pcm-blue"></textarea>
                    </div>
                </div>
                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" onclick="closeModal()" class="px-4 py-2 border border-slate-200 text-slate-600 rounded-md text-sm hover:bg-slate-50">Đóng</button>
                    <button type="submit" id="btnSubmit" class="bg-pcm-blue text-white px-5 py-2 rounded-md text-sm font-bold hover:bg-blue-800 transition flex items-center">
                        <i class="fas fa-save mr-2"></i> Lưu
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    let currentMode = 'create';
    const modal = document.getElementById('customerModal');
    const dialog = document.getElementById('modalDialog');
    
    function openModal(mode, id = 0) {
        currentMode = mode;
        document.getElementById('customerForm').reset();
        $('#MaNguoiDung').val(0);
        
        if (mode === 'create') {
            document.getElementById('modalTitle').innerText = 'Thêm Khách Hàng Mới';
            $('#Email').prop('readonly', false);
            $('#passRequired').show();
            showModal();
        } else {
            document.getElementById('modalTitle').innerText = 'Cập nhật Khách Hàng #' + id;
            $('#Email').prop('readonly', true);
            $('#passRequired').hide();
            $.get('/AdminCustomer/GetCustomer/' + id, function(res) {
                if(res.success) {
                    $('#MaNguoiDung').val(res.data.MaNguoiDung);
                    $('#HoTen').val(res.data.HoTen);
                    $('#Email').val(res.data.Email);
                    $('#SoDienThoai').val(res.data.SoDienThoai);
                    $('#DiaChi').val(res.data.DiaChi);
                    $('#TrangThaiTaiKhoan').val(res.data.TrangThaiTaiKhoan);
                    showModal();
                }
            });
        }
    }
    
    function showModal() {
        modal.classList.remove('hidden');
        setTimeout(() => { dialog.classList.remove('scale-95','opacity-0'); dialog.classList.add('scale-100','opacity-100'); }, 10);
    }
    
    function closeModal() {
        dialog.classList.add('scale-95','opacity-0'); dialog.classList.remove('scale-100','opacity-100');
        setTimeout(() => modal.classList.add('hidden'), 200);
    }
    
    function submitForm(e) {
        e.preventDefault();
        let url = currentMode === 'create' ? '/AdminCustomer/Create' : '/AdminCustomer/Edit';
        let formData = new FormData(document.getElementById('customerForm'));
        $.ajax({ url, type: 'POST', data: formData, processData: false, contentType: false,
            success: function(res) {
                if(res.success) { closeModal(); Swal.fire({icon:'success',title:'Thành công',text:res.message,timer:1500,showConfirmButton:false}).then(()=>location.reload()); }
                else Swal.fire({icon:'error',title:'Lỗi',text:res.message});
            }
        });
    }
    
    function toggleStatus(id, name) {
        Swal.fire({ title: 'Thay đổi trạng thái?', text: `Thay đổi trạng thái tài khoản của ${name}?`, icon:'question', showCancelButton:true, confirmButtonText:'Đồng ý', cancelButtonText:'Hủy', confirmButtonColor:'#007cc2' })
        .then(r => {
            if(r.isConfirmed)
                $.post('/AdminCustomer/ToggleStatus', { id }, function(res) {
                    if(res.success) Swal.fire({icon:'success',title:'Cập nhật!',timer:1500,showConfirmButton:false}).then(()=>location.reload());
                    else Swal.fire({icon:'error',text:res.message});
                });
        });
    }
    
    function deleteCustomer(id, name) {
        Swal.fire({ title:'Xóa khách hàng?', html:`Khóa hàng <b>${name}</b> sẽ bị xóa vĩnh viễn!`, icon:'warning', showCancelButton:true, confirmButtonColor:'#ef4444', confirmButtonText:'Xóa', cancelButtonText:'Hủy' })
        .then(r => {
            if(r.isConfirmed)
                $.post('/AdminCustomer/Delete/' + id, function(res) {
                    if(res.success) Swal.fire({icon:'success',title:'Đã xóa!',timer:1500,showConfirmButton:false}).then(()=>location.reload());
                    else Swal.fire({icon:'error',text:res.message});
                });
        });
    }
</script>
