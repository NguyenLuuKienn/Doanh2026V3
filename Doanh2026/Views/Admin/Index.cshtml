@model IEnumerable<Doanh2026.Models.DonHang>
@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- Page Header -->
<div class="mb-6 flex flex-col sm:flex-row justify-between sm:items-center p-1">
    <div>
        <h1 class="text-2xl font-bold text-slate-800">Tổng quan hệ thống</h1>
        <p class="text-xs text-slate-500 mt-1">Theo dõi hoạt động kinh doanh và hiệu suất cửa hàng PC Market.</p>
    </div>
    <div class="mt-4 sm:mt-0 flex gap-2">
        <button class="bg-white border border-slate-200 text-slate-600 px-3 py-1.5 rounded-md text-xs font-semibold hover:bg-slate-50 shadow-sm transition">
            <i class="far fa-calendar-alt mr-1"></i> Hôm nay
        </button>
        <button class="bg-pcm-blue text-white px-3 py-1.5 rounded-md text-xs font-semibold shadow-md shadow-pcm-blue/20 hover:bg-blue-700 transition">
            <i class="fas fa-download mr-1"></i> Xuất Báo Cáo
        </button>
    </div>
</div>

<!-- Stats Widgets -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    
    <!-- Widget 1: Revenue -->
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100 flex items-start justify-between relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-24 h-24 bg-blue-50 rounded-bl-full -z-10 group-hover:bg-blue-100 transition duration-500"></div>
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Tổng Doanh Thu</p>
            <h3 class="text-2xl font-black text-slate-800">
                @((ViewBag.TotalRevenue as decimal? ?? 0).ToString("N0"))<sup class="text-sm font-bold text-slate-500 ml-0.5">đ</sup>
            </h3>
            <div class="mt-2 flex items-center text-[11px] font-medium text-green-600">
                <i class="fas fa-arrow-up mr-1 text-[10px]"></i>
                <span>12.5% so với tháng trước</span>
            </div>
        </div>
        <div class="w-10 h-10 rounded-lg bg-blue-100 text-pcm-blue flex items-center justify-center text-lg shadow-inner">
            <i class="fas fa-wallet"></i>
        </div>
    </div>

    <!-- Widget 2: Orders -->
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100 flex items-start justify-between relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-24 h-24 bg-emerald-50 rounded-bl-full -z-10 group-hover:bg-emerald-100 transition duration-500"></div>
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Tổng Đơn Hàng</p>
            <h3 class="text-2xl font-black text-slate-800">@((ViewBag.TotalOrders as int? ?? 0).ToString("N0"))</h3>
            <div class="mt-2 flex items-center text-[11px] font-medium text-green-600">
                <i class="fas fa-arrow-up mr-1 text-[10px]"></i>
                <span>5.2% so với tháng trước</span>
            </div>
        </div>
        <div class="w-10 h-10 rounded-lg bg-emerald-100 text-emerald-600 flex items-center justify-center text-lg shadow-inner">
            <i class="fas fa-shopping-bag"></i>
        </div>
    </div>

    <!-- Widget 3: Customers -->
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100 flex items-start justify-between relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-24 h-24 bg-amber-50 rounded-bl-full -z-10 group-hover:bg-amber-100 transition duration-500"></div>
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Khách Hàng</p>
            <h3 class="text-2xl font-black text-slate-800">@((ViewBag.TotalCustomers as int? ?? 0).ToString("N0"))</h3>
            <div class="mt-2 flex items-center text-[11px] font-medium text-red-500">
                <i class="fas fa-arrow-down mr-1 text-[10px]"></i>
                <span>1.2% so với tháng trước</span>
            </div>
        </div>
        <div class="w-10 h-10 rounded-lg bg-amber-100 text-amber-600 flex items-center justify-center text-lg shadow-inner">
            <i class="fas fa-user-check"></i>
        </div>
    </div>

    <!-- Widget 4: Products -->
    <div class="bg-white rounded-xl p-5 shadow-sm border border-slate-100 flex items-start justify-between relative overflow-hidden group">
        <div class="absolute right-0 top-0 w-24 h-24 bg-purple-50 rounded-bl-full -z-10 group-hover:bg-purple-100 transition duration-500"></div>
        <div>
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Sản Phẩm Đang Bán</p>
            <h3 class="text-2xl font-black text-slate-800">@((ViewBag.TotalProducts as int? ?? 0).ToString("N0"))</h3>
            <div class="mt-2 flex items-center text-[11px] font-medium text-slate-400">
                <i class="fas fa-minus mr-1 text-[10px]"></i>
                <span>Không đổi</span>
            </div>
        </div>
        <div class="w-10 h-10 rounded-lg bg-purple-100 text-purple-600 flex items-center justify-center text-lg shadow-inner">
            <i class="fas fa-box-open"></i>
        </div>
    </div>
</div>

<!-- Main Section: Charts & Tables -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    
    <!-- Table: Recent Orders -->
    <div class="lg:col-span-2 bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
            <h3 class="font-bold text-slate-800 text-[15px]"><i class="fas fa-clipboard-list text-pcm-blue mr-2"></i>Đơn hàng gần đây</h3>
            <a href="#" class="text-[12px] font-semibold text-pcm-blue hover:text-blue-800 transition">Xem tất cả</a>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-[11px] uppercase tracking-wider">
                        <th class="py-3 px-5 font-bold">Mã ĐH</th>
                        <th class="py-3 px-5 font-bold">Khách Hàng</th>
                        <th class="py-3 px-5 font-bold text-right">Tổng Tiền</th>
                        <th class="py-3 px-5 font-bold text-center">Trạng Thái</th>
                        <th class="py-3 px-5 font-bold">Ngày Đặt</th>
                        <th class="py-3 px-5 font-bold text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="text-[13px] text-slate-700 divide-y divide-slate-100">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var order in Model)
                        {
                            var statusClass = "bg-slate-100 text-slate-600";
                            var statusIcon = "fa-clock";
                            
                            if(order.TrangThaiDonHang?.TenTrangThai.Contains("Chờ") == true) { statusClass = "bg-amber-100 text-amber-700"; statusIcon = "fa-spinner fa-spin"; }
                            if(order.TrangThaiDonHang?.TenTrangThai.Contains("Đang giao") == true) { statusClass = "bg-blue-100 text-blue-700"; statusIcon = "fa-truck text-[9px]"; }
                            if(order.TrangThaiDonHang?.TenTrangThai.Contains("Đã giao") == true || order.TrangThaiDonHang?.TenTrangThai.Contains("Hoàn thành") == true) { statusClass = "bg-emerald-100 text-emerald-700"; statusIcon = "fa-check"; }
                            if(order.TrangThaiDonHang?.TenTrangThai.Contains("Hủy") == true) { statusClass = "bg-red-100 text-red-700"; statusIcon = "fa-times"; }

                            <tr class="hover:bg-slate-50 transition group">
                                <td class="py-3 px-5 font-bold text-slate-800">#@order.MaDonHang</td>
                                <td class="py-3 px-5 font-semibold text-pcm-blue">@order.TenNguoiNhan</td>
                                <td class="py-3 px-5 font-bold text-right">@((order.TongTien ?? 0).ToString("N0"))<sup class="text-xs font-normal">đ</sup></td>
                                <td class="py-3 px-5 text-center">
                                    <span class="inline-flex items-center px-2 py-1 rounded text-[10px] font-bold uppercase tracking-wider @statusClass">
                                        <i class="fas @statusIcon mr-1"></i> @(order.TrangThaiDonHang?.TenTrangThai ?? "N/A")
                                    </span>
                                </td>
                                <td class="py-3 px-5 text-slate-500 font-medium">@(order.NgayDat?.ToString("dd/MM/yyyy HH:mm"))</td>
                                <td class="py-3 px-5 text-center space-x-1">
                                    <button class="w-7 h-7 rounded bg-slate-100 text-slate-500 hover:bg-pcm-blue hover:text-white transition" title="Xem chi tiết"><i class="fas fa-eye text-xs"></i></button>
                                    <button class="w-7 h-7 rounded bg-slate-100 text-slate-500 hover:bg-amber-500 hover:text-white transition" title="Cập nhật"><i class="fas fa-edit text-xs"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="py-8 text-center text-slate-400 font-medium"><i class="fas fa-inbox text-3xl mb-2 text-slate-300 block"></i> Chưa có đơn hàng nào !</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Chart: Doanh thu Demo -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden flex flex-col">
        <div class="px-5 py-4 border-b border-slate-100 bg-slate-50/50">
            <h3 class="font-bold text-slate-800 text-[15px]"><i class="fas fa-chart-line text-pcm-blue mr-2"></i>Thống kê Doanh Thu</h3>
        </div>
        <div class="p-5 flex-1 w-full bg-white relative flex items-center justify-center">
            <!-- Mock Chart Wrapper -->
            <canvas id="revenueChart" class="w-full h-full"></canvas>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // Init demo chart
        document.addEventListener('DOMContentLoaded', function() {
            var ctx = document.getElementById('revenueChart').getContext('2d');
            var myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'CN'],
                    datasets: [{
                        label: 'Doanh thu (Tr VNĐ)',
                        data: [12, 19, 15, 25, 22, 30, 42],
                        backgroundColor: '#007cc2',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { borderDash: [2, 4], color: '#f1f5f9' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}
